# ============================================
# ML Service — Environment Variables
# ============================================

# LLM API (Groq free tier for PR summarization)
GROQ_API_KEY=your_groq_api_key_here

# Model storage
MODEL_PATH=./app/models/saved/

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Backend API URL (for fetching data)
BACKEND_API_URL=http://backend:5000/api
